# ==============================================================================
# Middle Server - 초기 설정 예시 파일
# ==============================================================================
#
# 이 파일을 'middle.conf' 라는 이름으로 복사한 후, 본인의 환경에 맞게
# 아래 항목들을 수정하여 사용하세요.
#
# 명령어: cp middle-server/config/middle.conf.example middle-server/config/middle.conf
#
# ------------------------------------------------------------------------------

# [1. 터널 전용 사용자]
#
# Middle Server에 생성할, 터널 연결 수신 전용 사용자의 이름을 지정합니다.
# (예: tunnel, tunnel_user 등)
TUNNEL_USER="tunnel"


# ------------------------------------------------------------------------------

# [2. 방화벽에 허용할 포트 목록]
#
# 외부에서 접속할 수 있도록 방화벽(ufw)에서 열어줄 터널 포트 목록을 지정합니다.
# 여러 개를 설정할 경우, 큰따옴표 안에 공백으로 구분하여 나열합니다.
#
# Middle Server 자체에 SSH로 접속하기 위한 관리용 SSH 포트는 스크립트가
# 자동으로 감지해서 함께 허용합니다.
#
# --- 예시 ---
#
# Target Server의 SSH를 외부 22222번으로 노출하고, 웹 서비스를 8080번으로
# 노출하려면 다음처럼 설정합니다.
#
# TUNNEL_PORTS_TO_OPEN="22222 8080"
#
# ------------------------------------------------------------------------------

# 아래에 실제 사용할 터널 포트 목록을 입력하세요.
TUNNEL_PORTS_TO_OPEN="22222"


# ------------------------------------------------------------------------------

# [3. ufw 자동 활성화 여부]
#
# false: ufw 규칙만 추가합니다. ufw가 꺼져 있으면 계속 비활성 상태로 둡니다.
# true:  ufw가 꺼져 있으면 스크립트가 ufw를 활성화합니다.
#
# 원격 서버에서 기존 서비스 접속을 실수로 막지 않도록 기본값은 false를 권장합니다.
ENABLE_UFW="false"
