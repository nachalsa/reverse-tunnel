# ==============================================================================
# Target Server - 역방향 SSH 터널 설정 예시 파일
# ==============================================================================
#
# 이 파일을 'tunnel.conf' 라는 이름으로 복사한 후, 본인의 환경에 맞게
# 아래 항목들을 수정하여 사용하세요.
#
# 명령어: cp target-server/config/tunnel.conf.example target-server/config/tunnel.conf
#
# ------------------------------------------------------------------------------

# [1. Middle Server 터널 접속 별칭]
#
# setup.sh가 Target Server의 ~/.ssh/config에 생성할 터널용 Host 별칭입니다.
# 관리자 접속용 별칭과 같을 필요는 없습니다.
MIDDLE_SERVER_HOST_ALIAS="pitunnel"

# Middle Server에 생성된 터널 전용 사용자입니다.
MIDDLE_SERVER_TUNNEL_USER="tunnel"


# ------------------------------------------------------------------------------

# [2. 생성할 터널 목록]
#
# "외부포트:내부IP:내부포트" 형식입니다.
# 여러 개를 설정할 경우, 큰따옴표 안에 공백으로 구분하여 나열합니다.
#
# 예시 1: Target Server의 SSH를 Middle Server의 22222번 포트로 노출
# TUNNELS="22222:localhost:22"
#
# 예시 2: Target Server의 웹 서버를 Middle Server의 8080번 포트로 노출
# TUNNELS="8080:localhost:80"
#
# 예시 3: 여러 터널 동시 사용
# TUNNELS="22222:localhost:22 8080:localhost:80"
#
# ------------------------------------------------------------------------------

# 아래에 실제 사용할 터널 설정을 입력하세요.
TUNNELS="22222:localhost:22"
